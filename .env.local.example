# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: override the default model used for generation + edit chat
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-side ONLY. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# Price IDs for the three plans (create Products/Prices in the Stripe dashboard)
STRIPE_PRICE_BASIC=price_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx
STRIPE_PRICE_AGENCY=price_xxxxxxxx

# ---- Resend (Agency cold-email tool) ----
RESEND_API_KEY=re_xxxxxxxx
# Verified sender address, e.g. "Webcove <hello@yourdomain.com>"
RESEND_FROM_EMAIL=Webcove <onboarding@resend.dev>

# ---- App ----
# Used to build public site URLs and Stripe redirect URLs. No trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
